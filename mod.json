{
	"geode": "5.5.3",
	"gd": {
		"win": "2.2081",
		"mac": "2.2081",
		"android": "2.2081"
	},
	"id": "memr404.startpractice",
	"name": "Start Practice Button",
	"version": "v0.4.0",
	"developer": "memr404",
	"description": "This mod adds a new button before the start of the level to start practice.",
	"tags": ["interface", "offline"],
	"dependencies": {
		"geode.node-ids": ">=1.16.0"
	},
	"links": {
		"source": "https://github.com/memr404/StartPractice"
	},
	"settings": {
		"use-menu-buttons": {
			"name": "Place Button in Menu with Buttons",
			"type": "bool",
			"default": false
		},
		"show-only-practice": {
			"name": "Show only the practice button",
			"type": "bool",
			"default": false,
			"enable-if": "!use-menu-buttons"
		},
		"show-only-practice-on-editor": {
			"name": "Show only the practice button in editor",
			"type": "bool",
			"default": false,
			"enable-if": "!use-menu-buttons"
		}
	}
}
